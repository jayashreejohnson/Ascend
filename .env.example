# Anthropic (default provider until GMI arrives)
ANTHROPIC_API_KEY=

# Model identifier used by llm_client (override per provider).
# Anthropic default: claude-sonnet-4-6
# GMI OpenAI-route example: meta-llama/Llama-3.3-70B-Instruct
DEFAULT_MODEL=claude-sonnet-4-6

# GMI inference cloud — OpenAI-compatible route (drop in key at kickoff).
# llm_client switches to GMI automatically once BOTH values below are set.
# Endpoint confirmed from GMI quickstart; get the key at console.gmicloud.ai.
GMI_API_KEY=
GMI_ENDPOINT=https://api.gmicloud.ai/v1

# Phinite multi-agent OS (drop in at kickoff)
PHINITE_API_KEY=
PHINITE_PROJECT=

# Postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/research_match
